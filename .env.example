# Database
# Override POSTGRES_HOST_PORT if 5432 is taken on the host (e.g. another Postgres already running).
# DATABASE_URL must match POSTGRES_HOST_PORT (this is what FastAPI on the host connects to).
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+asyncpg://vero:vero@localhost:5432/vero_lite

# Redis
# Override REDIS_HOST_PORT if 6379 is taken on the host.
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# LLM (Ollama on MS-S1 MAX)
OLLAMA_HOST=http://ms-s1-max:11434
OLLAMA_DEFAULT_MODEL=gemma4:26b

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
