# Database
# Override POSTGRES_HOST_PORT if 5432 is taken on the host (e.g. another Postgres already running).
# DATABASE_URL must match POSTGRES_HOST_PORT (this is what FastAPI on the host connects to).
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+asyncpg://vero:vero@localhost:5432/vero_lite
# The DB test suite owns a separate disposable database it drops on teardown, so it
# never touches the dev/demo DB. Left unset it is derived as <db>_test (e.g. vero_lite_test)
# on the same server as DATABASE_URL. Uncomment only to point the tests elsewhere.
# TEST_DATABASE_URL=postgresql+asyncpg://vero:vero@localhost:5432/vero_lite_test

# Redis
# Override REDIS_HOST_PORT if 6379 is taken on the host.
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# LLM (Ollama on MS-S1 MAX)
OLLAMA_HOST=http://ms-s1-max:11434
OLLAMA_DEFAULT_MODEL=gemma4:26b

# OCT demo — active vertical + recommender policy (PLAN-0013 AC-template).
# Defaults reproduce the energy vertical exactly. Swapping the demo onto a
# second vertical = set OCT_VERTICAL + the OCT_RECOMMEND_* policy for that
# ontology — no engine or UI code change (the UI re-skins from /meta).
OCT_VERTICAL=energy
# OCT_RECOMMEND_THRESHOLD=90               # measured_value escalation threshold (energy over-temp °C)
# OCT_RECOMMEND_ENTITY_TYPE=Asset          # ontology object_type the fail-safe rule targets
# OCT_RECOMMEND_ENTITY_ID_FIELD=asset_id   # event field holding that entity's primary key
# OCT_RECOMMEND_LABEL=over-temperature     # anomaly label in the fail-safe rule wording
#
# supply_chain (cold-chain logistics) demo — uncomment this block to re-skin:
# OCT_VERTICAL=supply_chain
# OCT_RECOMMEND_THRESHOLD=8
# OCT_RECOMMEND_ENTITY_TYPE=Shipment
# OCT_RECOMMEND_ENTITY_ID_FIELD=shipment_id
# OCT_RECOMMEND_LABEL=cold-chain temperature breach

# API authentication (PLAN-0047 Step 1, SD-1 = static per-person API keys).
# Default ON (fail-closed): every state-changing route (approve/execute,
# /warm, /sleep, /intake/generate, and the run/gate-resolve endpoints) needs
# "Authorization: Bearer <raw-key>". API_KEYS maps sha256(raw-key) -> person_id;
# generate a key + digest pair with:
#   python -c "import secrets,hashlib; k=secrets.token_urlsafe(32); print('key:', k); print('sha256:', hashlib.sha256(k.encode()).hexdigest())"
# API_KEYS={"<sha256-hex>": "appr-somchai"}
# Local demo box without keys: opt out explicitly (restores pre-authn behavior):
# API_AUTH_ENABLED=false

# Procurement OPERATE demo (Control-leg v1, View H — PLAN-0054). Runs the procurement
# vertical with auth ON + an operator key for ONE approver principal (appr-pm), and
# auto-seeds ONE waiting_human 'emergency_sourcing_round' run at startup so the OCT
# Monitor has a governed gate to act on. Deterministic (no MS-S1). The
# .claude/launch.json 'oct-demo-procurement' config (port 8101) sets these; the block
# below is the manual-run equivalent (generate the key/digest with the one-liner above —
# the RAW key is what the operator types to log in; never commit it, CLAUDE.md §8):
# OCT_VERTICAL=procurement
# API_AUTH_ENABLED=true
# OCT_DEMO_SEED_OPERATE=true
# API_KEYS={"<sha256-hex>": "appr-pm"}     # appr-pm = ผจก.จัดซื้อ, the tier-matched approver for ฿288,000

# Telegram notify + LLM warm control (PLAN-0014). Pings when an OCT local-LLM
# call fails because MS-S1 is unreachable, so you can power it on + warm it.
# Reuses the EXISTING harness bot (ADR-013 D5) — no new BotFather bot. Tokens
# come from env ONLY, never committed (CLAUDE.md §8); default-off so dev gets
# no pings. Arm it on the demo box. Also enables GET /warm + GET /sleep.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ENABLED=false
TELEGRAM_NOTIFY_COOLDOWN_S=600
OLLAMA_KEEP_ALIVE=30m
# Set to the demo box's reachable URL so the ping includes a tap-link to {base}/warm:
# OCT_PUBLIC_BASE_URL=http://192.168.1.50:8096

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
