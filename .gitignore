# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
dist/
build/

# uv
.uv-cache/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project-specific
*.log
local/
scratch/

# Ontology codegen outputs (ADR-008 D5; reproducible from <name>_v0.yaml)
verticals/*/generated/

# Strategy (confidential — see ADR-006 D2)
# Company-specific opportunity analysis, design partner names, deal structure.
# Public abstract strategy lives in docs/strategy/public/.
docs/strategy/private/

# Research (working notes — Tier 0 Cowork output, gitignored)
# Cowork research briefs + closeouts. Code tab may lift edited
# versions to docs/strategy/public/ in a future batch.
docs/research/private/

# Docker
.docker/

# Node (future frontend)
node_modules/
.next/

# Claude Code local harness config
.claude/settings.local.json

# Claude Code per-machine state (loop counters, session markers, tokens)
# Phase 1 (PLAN-0007) registers the directory; Phase 2 populates loop-counter.json.
.claude/state/

# Step 5b config-file fallback for the Sonnet classifier — belt-and-suspenders.
# The canonical location is ~/.claude/.anthropic_api_key (outside repo); this
# project-local entry blocks accidental commits if a developer places it inside.
.claude/.anthropic_api_key

# PLAN-0010 loop — messages are uncommitted by design (producer has no git
# per K-1; consumer processes in place then archives to processed/).
# Directory layout + schema specced in docs/plans/0010-step1-message-schema.md.
loop/inbox/*
loop/processed/*
!loop/inbox/.gitkeep
!loop/processed/.gitkeep
